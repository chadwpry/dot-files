[alias]
  br = "branch"
  ci = "commit"
  co = "checkout"
  df = "diff"
  lg = "log -p"
  st = "status"

[color]
  ui = "auto"

[color "branch"]
  current = "yellow reverse"
  local = "yellow"
  remote = "green"

[color "diff"]
  frag = "magenta bold"
  meta = "yellow bold"
  new = "green bold"
  old = "red bold"
  whitespace = "red reverse"

[color "status"]
  added = "yellow"
  changed = "green"
  untracked = "cyan"

[core]
  autocrlf = false
  editor = "nvim"
  whitespace = "fix,-indent-with-non-tab,trailing-space,cr-at-eol"

[credential]
  helper = "store"

[filter "lfs"]
  clean = "git-lfs clean -- %f"
  process = "git-lfs filter-process"
  required = true
  smudge = "git-lfs smudge -- %f"

[http]
  sslVerify = false

[init]
  defaultBranch = "main"

[lfs]
  enable = true

[mergetool "diffmerge"]
  cmd = "diffmerge --merge --result=$MERGED $LOCAL $BASE $REMOTE"
  trustExitCode = false

[pager]
  branch = false

[include]
  path = ~/.config/git/config-default

[include]
  path = ~/.config/git/config-identities
